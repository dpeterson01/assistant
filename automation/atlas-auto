#!/bin/zsh
# atlas-auto: Management tool for Atlas automation tasks
# Usage: atlas-auto <command> [args]

set -uo pipefail

AUTOMATION_DIR="$HOME/projects/personal/assistant/automation"
MANIFEST="$AUTOMATION_DIR/manifest.json"
LOG_DIR="$AUTOMATION_DIR/logs"
PLIST_DIR="$HOME/Library/LaunchAgents"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    echo "${BOLD}atlas-auto${NC} - Manage Atlas scheduled automation"
    echo ""
    echo "${BOLD}Usage:${NC}"
    echo "  atlas-auto list              Show all tasks with status"
    echo "  atlas-auto status            Quick health check"
    echo "  atlas-auto enable <task>     Enable a task"
    echo "  atlas-auto disable <task>    Disable a task"
    echo "  atlas-auto run <task>        Manually trigger a task"
    echo "  atlas-auto logs [task]       Show recent logs (all or specific task)"
    echo "  atlas-auto agents            List available Copilot CLI agents"
    echo "  atlas-auto setup             Load all launchd agents"
    echo "  atlas-auto teardown          Unload all launchd agents"
    echo ""
    echo "${BOLD}Tasks:${NC}"
    python3 -c "
import json
with open('$MANIFEST') as f: m = json.load(f)
for t in m['tasks']:
    print(f\"  {t['id']:<25} {t['schedule']:<15} {t['type']}\")
" 2>/dev/null || echo "  (manifest not found)"
}

cmd_list() {
    echo ""
    echo "${BOLD}Atlas Automation Tasks${NC}"
    echo "${DIM}$(printf '%.0s─' {1..70})${NC}"
    echo ""

    python3 << 'PYEOF'
import json, os, subprocess
from datetime import datetime

manifest_path = os.path.expanduser("~/projects/personal/assistant/automation/manifest.json")
plist_dir = os.path.expanduser("~/Library/LaunchAgents")

with open(manifest_path) as f:
    m = json.load(f)

for t in m["tasks"]:
    # Check if launchd agent is loaded
    plist = t.get("plist", "")
    result = subprocess.run(["launchctl", "list"], capture_output=True, text=True)
    loaded = plist in result.stdout if plist else False

    # Status indicators
    if not t["enabled"]:
        status = "\033[2m⏸  DISABLED\033[0m"
    elif loaded:
        status = "\033[0;32m●  ACTIVE\033[0m"
    else:
        status = "\033[1;33m○  NOT LOADED\033[0m"

    # Last run info
    if t.get("last_run"):
        last = t["last_run"][:16].replace("T", " ")
        if t.get("last_status") == "success":
            last_info = f"\033[0;32m✓ {last}\033[0m"
        else:
            last_info = f"\033[0;31m✗ {last}\033[0m"
    else:
        last_info = "\033[2m  never\033[0m"

    # Type badge
    if t["type"] == "automated":
        badge = "\033[0;36m[AUTO]\033[0m"
    else:
        badge = "\033[2m[REMIND]\033[0m"

    print(f"  {badge} {t['name']:<25} {t['schedule']:<15} {status}")
    print(f"        Last: {last_info}")
    if t.get("agent"):
        print(f"        Agent: \033[2m{t['agent']}\033[0m")
    print()

# Wake schedule
ws = m.get("wake_schedule", {})
if ws.get("enabled"):
    print(f"  \033[0;34m⏰ Wake Schedule\033[0m: {ws.get('time', '?')} ({ws.get('days', '?')})")
else:
    print(f"  \033[2m⏰ Wake Schedule: disabled\033[0m")
print()
PYEOF
}

cmd_status() {
    echo ""
    echo "${BOLD}Atlas Health Check${NC}"
    echo ""

    # Check Copilot CLI
    if command -v copilot &>/dev/null; then
        VERSION=$(copilot --version 2>/dev/null | head -1)
        echo "  ${GREEN}✓${NC} Copilot CLI: $VERSION"
    else
        echo "  ${RED}✗${NC} Copilot CLI: not found"
    fi

    # Check MCP config
    if [[ -f "$HOME/.copilot/mcp-config.json" ]]; then
        SERVER_COUNT=$(python3 -c "import json; print(len(json.load(open('$HOME/.copilot/mcp-config.json')).get('mcpServers',{})))" 2>/dev/null || echo "?")
        echo "  ${GREEN}✓${NC} MCP servers: $SERVER_COUNT configured"
    else
        echo "  ${RED}✗${NC} MCP config: missing"
    fi

    # Check agents
    AGENT_COUNT=$(ls "$HOME/.copilot/agents/"*.md 2>/dev/null | wc -l | tr -d ' ')
    if [[ $AGENT_COUNT -gt 0 ]]; then
        echo "  ${GREEN}✓${NC} Agent profiles: $AGENT_COUNT"
    else
        echo "  ${RED}✗${NC} Agent profiles: none found"
    fi

    # Check launchd agents
    LOADED=0
    TOTAL=0
    python3 -c "
import json, subprocess
m = json.load(open('$MANIFEST'))
result = subprocess.run(['launchctl', 'list'], capture_output=True, text=True)
loaded = 0
total = len(m['tasks'])
for t in m['tasks']:
    if t.get('plist','') in result.stdout:
        loaded += 1
print(f'{loaded}/{total}')
" 2>/dev/null | read COUNTS
    echo "  ${GREEN}✓${NC} LaunchAgents loaded: $COUNTS"

    # Check wake schedule
    PMSET_REPEATS=$(pmset -g sched 2>/dev/null | grep -c "wake" || echo "0")
    if [[ $PMSET_REPEATS -gt 0 ]]; then
        echo "  ${GREEN}✓${NC} Wake schedule: active ($PMSET_REPEATS events)"
    else
        echo "  ${YELLOW}○${NC} Wake schedule: not set (run: sudo pmset repeat wakeorpoweron MTWRFSU 06:15:00)"
    fi

    # Check context files
    CONTEXT_DIR="$HOME/projects/personal/assistant/context"
    CONTEXT_COUNT=$(ls "$CONTEXT_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ')
    echo "  ${GREEN}✓${NC} Context files: $CONTEXT_COUNT"

    echo ""
}

cmd_enable() {
    local TASK_ID=$1
    python3 -c "
import json
with open('$MANIFEST') as f: m = json.load(f)
found = False
for t in m['tasks']:
    if t['id'] == '$TASK_ID':
        t['enabled'] = True
        found = True
        break
if not found:
    print(f'Task not found: $TASK_ID')
    exit(1)
with open('$MANIFEST', 'w') as f: json.dump(m, f, indent=2)
print(f'Enabled: $TASK_ID')
"
    # Load the launchd agent
    PLIST=$(python3 -c "import json; m=json.load(open('$MANIFEST')); print([t['plist'] for t in m['tasks'] if t['id']=='$TASK_ID'][0])" 2>/dev/null)
    if [[ -n "$PLIST" && -f "$PLIST_DIR/$PLIST.plist" ]]; then
        launchctl load "$PLIST_DIR/$PLIST.plist" 2>/dev/null
        echo "  Loaded launchd agent: $PLIST"
    fi
}

cmd_disable() {
    local TASK_ID=$1
    python3 -c "
import json
with open('$MANIFEST') as f: m = json.load(f)
found = False
for t in m['tasks']:
    if t['id'] == '$TASK_ID':
        t['enabled'] = False
        found = True
        break
if not found:
    print(f'Task not found: $TASK_ID')
    exit(1)
with open('$MANIFEST', 'w') as f: json.dump(m, f, indent=2)
print(f'Disabled: $TASK_ID')
"
    # Unload the launchd agent
    PLIST=$(python3 -c "import json; m=json.load(open('$MANIFEST')); print([t['plist'] for t in m['tasks'] if t['id']=='$TASK_ID'][0])" 2>/dev/null)
    if [[ -n "$PLIST" ]]; then
        launchctl unload "$PLIST_DIR/$PLIST.plist" 2>/dev/null
        echo "  Unloaded launchd agent: $PLIST"
    fi
}

cmd_run() {
    local TASK_ID=$1
    SCRIPT=$(python3 -c "import json; m=json.load(open('$MANIFEST')); print([t['script'] for t in m['tasks'] if t['id']=='$TASK_ID'][0])" 2>/dev/null)
    if [[ -z "$SCRIPT" ]]; then
        echo "${RED}Task not found: $TASK_ID${NC}"
        return 1
    fi
    echo "${CYAN}Running: $TASK_ID${NC}"
    "$AUTOMATION_DIR/$SCRIPT"
}

cmd_logs() {
    local TASK_ID=${1:-}
    echo ""
    echo "${BOLD}Recent Logs${NC}"
    echo ""

    if [[ -n "$TASK_ID" ]]; then
        # Show logs for specific task
        LOG_FILE=$(ls -t "$LOG_DIR/$TASK_ID"-*.log 2>/dev/null | head -1)
        if [[ -n "$LOG_FILE" ]]; then
            echo "${DIM}$LOG_FILE${NC}"
            echo ""
            tail -50 "$LOG_FILE"
        else
            echo "  No logs found for: $TASK_ID"
        fi
    else
        # Show recent log files
        echo "${DIM}  Recent log files:${NC}"
        ls -lt "$LOG_DIR"/*.log 2>/dev/null | head -10 | while read line; do
            echo "  $line"
        done
        if [[ $(ls "$LOG_DIR"/*.log 2>/dev/null | wc -l) -eq 0 ]]; then
            echo "  No logs yet. Run a task first."
        fi
    fi
    echo ""
}

cmd_agents() {
    echo ""
    echo "${BOLD}Available Copilot CLI Agents${NC}"
    echo ""

    for agent_file in "$HOME/.copilot/agents/"*.md; do
        if [[ -f "$agent_file" ]]; then
            name=$(basename "$agent_file" .md)
            desc=$(grep "^description:" "$agent_file" 2>/dev/null | sed 's/description: *"//;s/"$//' | head -1)
            echo "  ${CYAN}$name${NC}"
            echo "    ${DIM}$desc${NC}"
            echo "    Run: copilot --agent=$name"
            echo ""
        fi
    done
}

cmd_setup() {
    echo "${BOLD}Loading all Atlas LaunchAgents...${NC}"
    echo ""

    python3 -c "
import json
m = json.load(open('$MANIFEST'))
for t in m['tasks']:
    if t['enabled']:
        print(t['plist'])
" 2>/dev/null | while read PLIST; do
        PLIST_FILE="$PLIST_DIR/$PLIST.plist"
        if [[ -f "$PLIST_FILE" ]]; then
            launchctl unload "$PLIST_FILE" 2>/dev/null
            launchctl load "$PLIST_FILE" 2>/dev/null
            echo "  ${GREEN}✓${NC} Loaded: $PLIST"
        else
            echo "  ${RED}✗${NC} Missing: $PLIST_FILE"
        fi
    done

    echo ""
    echo "To set up wake schedule: ${YELLOW}sudo pmset repeat wakeorpoweron MTWRFSU 06:15:00${NC}"
    echo ""
}

cmd_teardown() {
    echo "${BOLD}Unloading all Atlas LaunchAgents...${NC}"
    echo ""

    for plist_file in "$PLIST_DIR"/com.atlas.*.plist; do
        if [[ -f "$plist_file" ]]; then
            launchctl unload "$plist_file" 2>/dev/null
            echo "  ${YELLOW}○${NC} Unloaded: $(basename "$plist_file" .plist)"
        fi
    done
    echo ""
}

# Main dispatch
case "${1:-}" in
    list)       cmd_list ;;
    status)     cmd_status ;;
    enable)     cmd_enable "${2:?Task ID required}" ;;
    disable)    cmd_disable "${2:?Task ID required}" ;;
    run)        cmd_run "${2:?Task ID required}" ;;
    logs)       cmd_logs "${2:-}" ;;
    agents)     cmd_agents ;;
    setup)      cmd_setup ;;
    teardown)   cmd_teardown ;;
    help|--help|-h|"")  usage ;;
    *)          echo "Unknown command: $1"; usage; exit 1 ;;
esac
